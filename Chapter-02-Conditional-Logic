## 2. The Implementation (`decision_engine.js`)

```javascript
/**
 * CHAPTER 2 ASSIGNMENT: CONTROL FLOW & LOGIC
 * Scenario: Automated Bank Transaction Validator
 */

// --- SECTION 1: SYSTEM STATE ---
const accountOwner = "Muhammad Assam";
const accountBalance = 12500.75;
const accountType = "Gold"; // Options: Silver, Gold, Platinum
const isAccountActive = true;
const dailyLimit = 5000.00;

// --- SECTION 2: TRANSACTION REQUEST ---
let transactionAmount = 4200.00;
let isInternational = false;

console.log(`--- Processing Transaction for ${accountOwner} ---`);

// --- SECTION 3: CONDITIONAL LOGIC (The Decision Engine) ---

// Step 1: Security & Status Check
if (!isAccountActive) {
    console.log("REJECTED: Account is currently suspended.");
} 
// Step 2: Limit & Balance Validation
else if (transactionAmount > accountBalance) {
    console.log("REJECTED: Insufficient funds available.");
} 
else if (transactionAmount > dailyLimit) {
    console.log("REJECTED: Amount exceeds your daily security limit.");
} 
// Step 3: Success Pathway
else {
    console.log("VALIDATED: Funds are available and security limits cleared.");
    
    // Nested Logic: Calculate Transaction Fees using Switch
    let transactionFee = 0;

    switch (accountType) {
        case "Silver":
            transactionFee = isInternational ? 25.00 : 5.00;
            break;
        case "Gold":
            transactionFee = isInternational ? 15.00 : 2.00;
            break;
        case "Platinum":
            transactionFee = 0; // VIP Tier: No fees
            break;
        default:
            transactionFee = 10.00;
    }

    let finalDeduction = transactionAmount + transactionFee;
    console.log(`Transaction Fee Applied (${accountType}): $${transactionFee}`);
    console.log(`Total Amount to be Debited: $${finalDeduction.toFixed(2)}`);
    console.log(`Remaining Balance: $${(accountBalance - finalDeduction).toFixed(2)}`);
}

// --- SECTION 4: LOGICAL OPERATOR DEMO ---
// Checking for "VIP Quick Access" (Platinum or Balance > 50,000)
if (accountType === "Platinum" || accountBalance > 50000) {
    console.log("PRIORITY: This user qualifies for Priority Customer Support.");
}
